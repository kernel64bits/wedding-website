DATABASE_URL="file:./dev.db"
SESSION_SECRET=   # run: openssl rand -hex 32
BASE_URL=http://localhost:3000   # set to your production domain before go-live

# Photo storage (MinIO for local dev, real S3 in production)
S3_ENDPOINT=http://localhost:9000   # use http://minio:9000 inside Docker; real S3 endpoint in production
S3_BUCKET=wedding-photos
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin         # real AWS credentials in production
S3_SECRET_ACCESS_KEY=minioadmin
